{
  "manifest_version": 3,
  "name": "Bookmark To Top",
  "version": "1.0.1",
  "description": "Automatically moves each newly added bookmark to the top of its folder.",
  "permissions": ["bookmarks"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }

}